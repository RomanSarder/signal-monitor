{
  "name": "signal-monitor-backend",
  "version": "1.0.0",
  "description": "",
  "main": "app.ts",
  "directories": {
    "test": "test"
  },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "start": "npm run build:ts && fastify start --pretty-print -l info dist/app.js",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "dev": "npm run build:ts && concurrently -k -p \"[{name}]\" -n \"TypeScript,App\" -c \"yellow.bold,cyan.bold\" \"npm:watch:ts\" \"npm:dev:start\"",
    "dev:start": "fastify start --ignore-watch=.ts$ -w -l info -P dist/app.js",
    "worker:poll": "tsx src/workers/poll-worker/index.ts",
    "worker:score": "tsx src/workers/score-worker/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:studio": "drizzle-kit studio"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.104.1",
    "@fastify/autoload": "^6.0.0",
    "@fastify/cookie": "^11.0.2",
    "@fastify/env": "^6.0.0",
    "@fastify/error": "^4.2.0",
    "@fastify/jwt": "^10.1.0",
    "@fastify/redis": "^7.2.0",
    "@fastify/sensible": "^6.0.0",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.78.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "fastify-cli": "^8.0.0",
    "fastify-plugin": "^5.0.0",
    "ioredis": "^5.11.1",
    "pg": "^8.21.0",
    "pino-pretty": "^13.1.3",
    "postgres": "^3.4.9",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^25.9.2",
    "@types/pg": "^8.20.0",
    "c8": "^11.0.0",
    "concurrently": "^9.0.0",
    "dotenv": "^17.4.2",
    "drizzle-kit": "^0.31.10",
    "fastify-tsconfig": "^3.0.0",
    "ts-node": "^10.4.0",
    "tsx": "^4.22.4",
    "typescript": "~5.9.2",
    "vitest": "^4.1.8"
  }
}
